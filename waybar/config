{
  "reload_style_on_change": true,
  "layer": "top",
  "position": "top",
  "spacing": 0,
  "height": 35,
  "border-radius": 25,
  "margin-right": 10,
  "margin-left": 10,
  "margin-top": 2,
  "modules-left": ["clock", "cpu", "memory"],
  "modules-center": ["sway/workspaces", "group/center2" ],
  "modules-right": [
    "group/right1",
  ],

// GROUPS MODULE

  "group/center2": {
	"orientation": "inherit",
	"modules": [
    "custom/idle-indicator",
    "custom/notification-silencing-indicator",
    "custom/screenrecording-indicator", 
    "custom/update", 
	]
},


  "group/right1": {
	"orientation": "inherit",
	"modules": [
    "custom/media", 
    "tray",
    "custom/separator#blank",
    "custom/separator#blank",
    "pulseaudio",
    "bluetooth",
    "network",
	]
},

// MODULES

  "sway/workspaces": {
	  "on-click": "activate",
        "format": "{icon}",
        "format-icons": {
          "default": "’æä",
          "active": "’æä",
          "urgent": "’åÆ",
          "empty": "’ōā",
        },
      "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
    },
	},

    "cpu": {
    "interval": 5,
    "format": "{icon} ",
    "format-icons": ["¾░¬×", "¾░¬¤", "¾░¬Ā", "¾░¬Ī", "¾░¬ó", "¾░¬Ż", "¾░¬ż", "¾░¬ź"],
    "on-click": "foot btop"
    },

"memory": {
  "interval": 5,
  "format": "{icon} ",
  "format-icons": ["¾░¬×", "¾░¬¤", "¾░¬Ā", "¾░¬Ī", "¾░¬ó", "¾░¬Ż", "¾░¬ż", "¾░¬ź"],
  "on-click": "foot btop"
},

"clock": {
    "format": " {:%I:%M %p ŌĆó %a, %d/%m}     ",
    "format-alt": "{:%A, %d %B %Y}   ",
    "tooltip": false,
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
},

  "network": {
    "format-icons": ["¾░ż»", "¾░ż¤", "¾░żó", "¾░żź", "¾░ż©"],
    "format": "{icon}",
    "format-wifi": "{icon}",
    "format-ethernet": "<span size='11500'>¾░īś</span>",
    "format-disconnected": "<span size='11500'>¾░ż«</span>",
    "tooltip-format-wifi": "{essid} ({frequency} GHz)\nŌćŻ{bandwidthDownBytes}  ŌćĪ{bandwidthUpBytes}",
    "tooltip-format-ethernet": "ŌćŻ{bandwidthDownBytes}  ŌćĪ{bandwidthUpBytes}",
    "tooltip-format-disconnected": "Disconnected",
    "interval": 10,
    "spacing": 1,
    "on-click": "nmtui"
  },

  "bluetooth": {
    "format": "<span size='11500'>¾░é»</span>",
    "format-disabled": "<span size='11500'>¾░é▓</span>",
    "format-connected": "<span size='11500'>’Ŗō</span>",
    "format-no-controller": "",
    "tooltip-format": "Devices connected: {num_connections}",
    "on-click": "omarchy-launch-bluetooth"
  },

  "pulseaudio": {
    "format": "<span size='11500'>{icon}</span>",
    "on-click": "omarchy-launch-or-focus-tui wiremix",
    "on-click-right": "pamixer -t",
    "tooltip-format": "{volume}%",
    "scroll-step": 5,
    "format-muted": "Ņ╗©",
    "format-icons": {
      "default": [
        "’Ć” ",
        "’Ć¦ ",
        "’Ć© "
      ]
    }
  },
  
  "group/tray-expander": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 600,
      "children-class": "tray-group-item"
    },
    "modules": ["custom/expand-icon", "tray"]
  },

  "custom/expand-icon": {
    "format": "’üō",
    "tooltip": false
  },

  "tray": {
    "icon-size": 16,
    "spacing": 8
  },

"custom/media": {
  "exec": "title=$(playerctl metadata title 2>/dev/null); if [ -n \"$title\" ]; then echo \"’Ćü  ${title:0:25} \"; else echo \"’Ćü         No media           \"; fi",
  "interval": 10,
  "on-click": "playerctl play-pause"
},

  "custom/separator#blank": {
	  "format": " ",
	  "interval": "once",
	  "tooltip": false
},

  "custom/separator#dot": {
	  "format": "’æä ",
	  "interval": "once",
	  "tooltip": false
},

  "custom/idle-indicator": {
    "on-click": "omarchy-toggle-idle",
    "exec": "$OMARCHY_PATH/default/waybar/indicators/idle.sh",
    "signal": 9,
    "return-type": "json"
  },
}
